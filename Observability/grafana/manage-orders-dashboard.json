{
  "title": "Manage Orders API",
  "uid": "manage-orders-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "constant",
        "query": "manage-orders-api",
        "current": { "value": "manage-orders-api", "text": "manage-orders-api" },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_received_total{job=\"manage-orders-api\"})",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests por Segundo",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_received_total{job=\"manage-orders-api\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errores HTTP (4xx + 5xx)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_received_total{job=\"manage-orders-api\", code=~\"4..|5..\"})",
          "legendFormat": "Errores"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latencia p99 (ms)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"manage-orders-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU del Proceso (%)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total{job=\"manage-orders-api\"}[1m]) * 100",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memoria Usada (MB)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_working_set_bytes{job=\"manage-orders-api\"} / 1024 / 1024",
          "legendFormat": "Memoria"
        }
      ]
    },
    {
      "id": 7,
      "title": "Requests por Segundo por Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (controller, action, method) (rate(http_requests_received_total{job=\"manage-orders-api\"}[1m]))",
          "legendFormat": "{{method}} {{controller}}/{{action}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Latencia por Percentil (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"manage-orders-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{job=\"manage-orders-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p90"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"manage-orders-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "title": "Tasa de Errores por Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (controller, action, code) (rate(http_requests_received_total{job=\"manage-orders-api\", code=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{code}} {{controller}}/{{action}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Requests en curso (In-Flight)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "http_requests_in_progress{job=\"manage-orders-api\"}",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Top Endpoints más lentos (p99 ms)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sort_desc(histogram_quantile(0.99, sum by (controller, action, le) (rate(http_request_duration_seconds_bucket{job=\"manage-orders-api\"}[5m]))) * 1000)",
          "legendFormat": "{{controller}}/{{action}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "GC Collections .NET",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(dotnet_gc_collections_total{job=\"manage-orders-api\"}[1m])",
          "legendFormat": "GC Gen{{generation}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Hits vs Misses de Caché Redis",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_received_total{job=\"manage-orders-api\", action=\"GetById\", controller=\"Orden\"}[1m])",
          "legendFormat": "Requests GetById Orden"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_received_total{job=\"manage-orders-api\", action=\"GetById\", controller=\"Producto\"}[1m])",
          "legendFormat": "Requests GetById Producto"
        }
      ]
    },
    {
      "id": 14,
      "title": "Requests por Código HTTP",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (code) (http_requests_received_total{job=\"manage-orders-api\"})",
          "legendFormat": "HTTP {{code}}"
        }
      ]
    }
  ]
}